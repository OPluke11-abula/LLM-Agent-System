{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/OPluke11-abula/Portable-Agent-Protocol/main/spec/registry-schema.json",
  "title": "PAP Registry Index Schema",
  "description": "Portable Agent Protocol skill registry index.",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_version", "skills"],
  "properties": {
    "registry_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "skills": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/skill_descriptor"
      }
    }
  },
  "definitions": {
    "skill_descriptor": {
      "type": "object",
      "required": ["id", "name", "version", "description", "author", "path"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.:-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
