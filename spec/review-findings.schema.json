{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/OPluke11-abula/Portable-Agent-Protocol/main/spec/review-findings.schema.json",
  "title": "LAS/PAP Review Findings Schema",
  "description": "Structured review and security-gate findings with traceable evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "target",
    "review_type",
    "generated_at",
    "verdict",
    "risk_level",
    "changed_paths",
    "security_triggers",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "review_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "review_type": {
      "type": "string",
      "enum": ["code_review", "security_review"]
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "needs_changes", "blocked"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "changed_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "security_triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "auth_or_authorization",
          "secret_or_token_handling",
          "database_query_or_migration",
          "external_api_or_webhook",
          "file_parsing_or_upload",
          "command_execution_or_sandbox",
          "high_impact_policy_gate"
        ]
      },
      "uniqueItems": true
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/finding"
      }
    }
  },
  "definitions": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "description"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "symbol": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "code_symbol_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "symbol", "description"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "qualified_name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "evidence_query": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "code_graph_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caller", "callee", "path", "description"],
      "properties": {
        "caller": {
          "type": "string",
          "minLength": 1
        },
        "callee": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "edge_type": {
          "type": "string",
          "minLength": 1
        },
        "evidence_query": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "code_graph_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entrypoint_symbol",
        "propagation_path",
        "sink_symbol",
        "impacted_symbols",
        "linked_tests"
      ],
      "properties": {
        "entrypoint_symbol": {
          "$ref": "#/definitions/code_symbol_ref"
        },
        "propagation_path": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/code_graph_edge"
          },
          "minItems": 1
        },
        "sink_symbol": {
          "$ref": "#/definitions/code_symbol_ref"
        },
        "impacted_symbols": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/code_symbol_ref"
          },
          "minItems": 1
        },
        "linked_tests": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/code_symbol_ref"
          },
          "minItems": 1
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verdict",
        "severity",
        "category",
        "title",
        "entrypoint_trace",
        "propagation_trace",
        "sink_trace",
        "impact",
        "evidence",
        "remediation",
        "validation_status"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["valid", "invalid", "needs_validation", "not_applicable"]
        },
        "severity": {
          "type": "string",
          "enum": ["info", "low", "medium", "high", "critical"]
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "entrypoint_trace": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/trace"
          },
          "minItems": 1
        },
        "propagation_trace": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/trace"
          }
        },
        "sink_trace": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/trace"
          },
          "minItems": 1
        },
        "impact": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/trace"
          },
          "minItems": 1
        },
        "remediation": {
          "type": "string",
          "minLength": 1
        },
        "validation_status": {
          "type": "string",
          "enum": ["not_started", "reproduced", "not_reproduced", "reasoned", "fixed", "wont_fix"]
        },
        "code_graph_evidence": {
          "$ref": "#/definitions/code_graph_evidence"
        }
      }
    }
  }
}
