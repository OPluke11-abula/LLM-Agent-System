{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ai-agent-topology-viewer",
  "version": "0.1.1",
  "identifier": "com.opluke11.abula.ai-agent-topology-viewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Agent Topology Viewer",
        "width": 1400,
        "height": 900
      },
      {
        "label": "ceo-window",
        "title": "CEO Strategy Dashboard",
        "width": 1000,
        "height": 700,
        "visible": false
      },
      {
        "label": "dev-window",
        "title": "Developer Terminal Dashboard",
        "width": 1000,
        "height": 700,
        "visible": false
      },
      {
        "label": "auditor-window",
        "title": "Auditor Billing Dashboard",
        "width": 1000,
        "height": 700,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
